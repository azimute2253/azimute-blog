---
export const prerender = false;

import DashboardLayout from '../../../layouts/Dashboard.astro';
import NexusDashboard from '../../../components/NexusDashboard';
import { getNexusLocals } from '../../../lib/nexus/supabase';

const { user } = getNexusLocals(Astro.locals);
---
<DashboardLayout title="Portfolio">
  <div class="portfolio-header">
    <h1>Portfolio Nexus</h1>
    <p class="portfolio-user">Logged in as <strong>{user.email}</strong></p>
  </div>

  <NexusDashboard client:load />
</DashboardLayout>

<style>
  .portfolio-header {
    margin-bottom: 2rem;
  }

  h1 {
    margin-bottom: 0.25rem;
  }

  .portfolio-user {
    color: var(--az-text-muted);
    font-size: 0.9rem;
  }

  .portfolio-user strong {
    color: var(--az-text);
  }
</style>
