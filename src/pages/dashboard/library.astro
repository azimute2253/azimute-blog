---
export const prerender = false;

import DashboardLayout from '../../layouts/Dashboard.astro';

const categories = [
  {
    name: 'Papers',
    href: '/dashboard/papers',
    icon: 'book-open',
    description: 'Artigos acadêmicos',
  },
  {
    name: 'Projects',
    href: '/dashboard/projects',
    description: 'Projetos e iniciativas',
    icon: 'folder',
  },
  {
    name: 'Documents',
    href: '/dashboard/documents',
    description: 'Documentos gerais',
    icon: 'file',
  },
  {
    name: 'Reports',
    href: '/dashboard/reports',
    description: 'Relatórios de pesquisa',
    icon: 'file-text',
  },
];

const icons = {
  'book-open': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />',
  'folder': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />',
  'file': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />',
  'file-text': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />',
};
---
<DashboardLayout title="Relatórios">
  <div class="library-container">
    <h1>Relatórios</h1>
    <p class="subtitle">Escolha uma categoria</p>

    <div class="categories-grid">
      {categories.map((category) => (
        <a href={category.href} class="category-card">
          <svg class="category-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <Fragment set:html={icons[category.icon]} />
          </svg>
          <h3>{category.name}</h3>
          <p>{category.description}</p>
        </a>
      ))}
    </div>
  </div>
</DashboardLayout>

<style>
  .library-container {
    max-width: 800px;
    margin: 0 auto;
  }

  h1 {
    font-family: var(--az-font-display);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--az-text);
    margin-bottom: 0.5rem;
  }

  .subtitle {
    font-family: var(--az-font-body);
    font-size: 1.125rem;
    color: var(--az-text-muted);
    margin-bottom: 3rem;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .category-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2.5rem 2rem;
    background: var(--az-deep);
    border: 1px solid var(--az-surface);
    border-radius: 0.75rem;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .category-card:hover {
    border-color: var(--az-compass);
    background: var(--az-surface);
    transform: translateY(-2px);
  }

  .category-icon {
    color: var(--az-compass);
    margin-bottom: 1.5rem;
  }

  .category-card h3 {
    font-family: var(--az-font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--az-text);
    margin-bottom: 0.5rem;
  }

  .category-card p {
    font-family: var(--az-font-body);
    font-size: 0.875rem;
    color: var(--az-text-muted);
  }

  @media (max-width: 768px) {
    .categories-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
