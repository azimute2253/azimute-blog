---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';

export async function getStaticPaths() {
  const wanders = await getCollection('wanders-pt');
  const sorted = wanders.sort((a, b) => a.data.date.localeCompare(b.data.date));
  return sorted.map((wander, i) => ({
    params: { date: wander.data.date },
    props: {
      wander,
      prev: i > 0 ? sorted[i - 1] : null,
      next: i < sorted.length - 1 ? sorted[i + 1] : null,
    },
  }));
}

const { wander, prev, next } = Astro.props;
const { Content } = await render(wander);
const { title, theme, date, readingTime, layers } = wander.data;
---

<Base title={title} description={wander.data.excerpt}>
  <article>
    <div class="post-header">
      <span class="post-tag">hypnagogic wander · {theme}</span>
      <h1 class="post-title">{title}</h1>
      <div class="post-meta">
        {date} · {readingTime} · {layers.join(' ')}
      </div>
    </div>

    <div class="post-content">
      <Content />
    </div>

    <nav class="post-nav">
      <div class="post-nav-row">
        {next ? (
          <a href={`/pt/wander/${next.data.date}/`} class="nav-prev">← {next.data.title}</a>
        ) : <span />}
        {prev ? (
          <a href={`/pt/wander/${prev.data.date}/`} class="nav-next">{prev.data.title} →</a>
        ) : <span />}
      </div>
      <a href="/pt/" class="nav-all">Todos os wanders</a>
    </nav>
  </article>
</Base>

<style>
  .post-nav {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--az-surface);
  }
  .post-nav-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .nav-prev, .nav-next {
    font-family: var(--az-font-mono);
    font-size: 0.8rem;
    color: var(--az-text-muted);
    max-width: 45%;
  }
  .nav-next {
    text-align: right;
  }
  .nav-prev:hover, .nav-next:hover {
    color: var(--az-compass);
  }
  .nav-all {
    font-family: var(--az-font-mono);
    font-size: 0.875rem;
    color: var(--az-text-muted);
  }
  .nav-all:hover {
    color: var(--az-compass);
  }
</style>
