---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import fs from 'fs';
import path from 'path';

const { slug } = Astro.params;

// Read HTML from public/research/
const htmlPath = path.join(process.cwd(), 'public', 'research', `${slug}.html`);

if (!fs.existsSync(htmlPath)) {
  return Astro.redirect('/dashboard/reports?error=not-found');
}

const htmlContent = fs.readFileSync(htmlPath, 'utf8');

// Extract title from HTML
const titleMatch = htmlContent.match(/<h1[^>]*>(.*?)<\/h1>/);
const title = titleMatch ? titleMatch[1] : 'Research Report';
---
<Base title={title}>
  <article class="research-report" set:html={htmlContent} />
</Base>

<style is:global>
  .research-report {
    max-width: 900px;
    margin: 2rem auto;
    padding: 0 1rem;
  }

  .research-report h1 {
    font-family: var(--az-font-display);
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--az-compass);
    border-bottom: 2px solid var(--az-surface);
    padding-bottom: 1rem;
  }

  .research-report h2 {
    font-family: var(--az-font-display);
    font-size: 1.75rem;
    font-weight: 600;
    margin-top: 3rem;
    margin-bottom: 1rem;
    color: var(--az-text);
  }

  .research-report h3 {
    font-family: var(--az-font-display);
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--az-text);
  }

  .research-report h4 {
    font-family: var(--az-font-display);
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--az-text-muted);
  }

  .research-report p, .research-report li {
    color: var(--az-text-muted);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .research-report ul, .research-report ol {
    margin-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .research-report li {
    margin-bottom: 0.5rem;
  }

  .research-report strong {
    color: var(--az-text);
    font-weight: 600;
  }

  .research-report em {
    color: var(--az-compass);
    font-style: italic;
  }

  .research-report blockquote {
    background: var(--az-surface);
    border-left: 3px solid var(--az-compass);
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    border-radius: 4px;
    color: var(--az-text-muted);
  }

  .research-report code {
    font-family: var(--az-font-mono);
    background: var(--az-surface);
    padding: 0.2rem 0.4rem;
    border-radius: 3px;
    font-size: 0.9em;
    color: var(--az-signal);
  }

  .research-report pre {
    background: var(--az-deep);
    border: 1px solid var(--az-surface);
    padding: 1rem;
    border-radius: 6px;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .research-report pre code {
    background: none;
    padding: 0;
  }

  .research-report a {
    color: var(--az-compass);
    text-decoration: none;
  }

  .research-report a:hover {
    text-decoration: underline;
  }

  .research-report table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }

  .research-report th,
  .research-report td {
    padding: 0.75rem 1rem;
    text-align: left;
    border: 1px solid var(--az-surface);
  }

  .research-report th {
    background: var(--az-deep);
    color: var(--az-text);
    font-weight: 600;
  }

  .research-report td {
    color: var(--az-text-muted);
  }

  .research-report hr {
    border: none;
    border-top: 1px solid var(--az-surface);
    margin: 2rem 0;
  }

  /* Handle original styles from research HTML */
  .research-report .container {
    max-width: 100%;
    margin: 0;
    padding: 0;
  }

  .research-report header {
    text-align: center;
    padding: 2rem 0;
    border-bottom: 2px solid var(--az-surface);
    margin-bottom: 2rem;
  }

  .research-report .metadata {
    background: var(--az-deep);
    border: 1px solid var(--az-surface);
    border-radius: 6px;
    padding: 1rem;
    margin-bottom: 2rem;
    font-family: var(--az-font-mono);
    font-size: 0.875rem;
    color: var(--az-text-muted);
  }

  .research-report .highlight {
    background: var(--az-surface);
    border-left: 3px solid var(--az-compass);
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    border-radius: 4px;
  }

  .research-report section {
    margin: 2rem 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .research-report {
      padding: 0 0.75rem;
    }

    .research-report h1 {
      font-size: 2rem;
    }

    .research-report h2 {
      font-size: 1.5rem;
    }

    .research-report table {
      font-size: 0.875rem;
    }

    .research-report th,
    .research-report td {
      padding: 0.5rem;
    }
  }
</style>
