---
export const prerender = false;

import Base from '../layouts/Base.astro';
import { createSupabaseClient } from '../lib/supabase';
import { getLang } from '../lib/i18n';

const lang = getLang(Astro.cookies, Astro.url);

let error = '';
let success = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const password = formData.get('password') as string;

  const supabase = createSupabaseClient(Astro.request, Astro.cookies);
  const { error: updateError } = await supabase.auth.updateUser({ password });

  if (updateError) {
    error = updateError.message;
  } else {
    success = lang === 'pt' 
      ? 'Senha atualizada! Redirecionando para login...'
      : 'Password updated! Redirecting to login...';
  }
}
---
<Base title={lang === 'pt' ? 'Atualizar Senha' : 'Update Password'}>
  <div class="auth-page">
    <h1>{lang === 'pt' ? 'Atualizar Senha' : 'Update Password'}</h1>
    <p class="auth-subtitle">
      {lang === 'pt' ? 'Digite sua nova senha.' : 'Enter your new password.'}
    </p>

    {error && <div class="auth-error">{error}</div>}
    {success && <div class="auth-success">{success}</div>}

    {!success && (
      <form method="POST" class="auth-form">
        <label for="password">
          {lang === 'pt' ? 'Nova Senha' : 'New Password'}
        </label>
        <input 
          type="password" 
          id="password" 
          name="password" 
          required 
          minlength="6"
          autocomplete="new-password" 
        />
        <p class="password-hint">
          {lang === 'pt' ? 'Mínimo 6 caracteres' : 'Minimum 6 characters'}
        </p>

        <button type="submit" class="auth-btn">
          {lang === 'pt' ? 'Atualizar Senha' : 'Update Password'}
        </button>
      </form>
    )}
  </div>
</Base>

{success && (
  <script>
    setTimeout(() => {
      window.location.href = '/login';
    }, 2000);
  </script>
)}

<style>
  .auth-page {
    max-width: 400px;
    margin: 2rem auto;
  }

  .auth-subtitle {
    color: var(--az-text-muted);
    margin-bottom: 2rem;
    font-size: 1rem;
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .auth-form label {
    font-family: var(--az-font-display);
    font-size: 0.875rem;
    color: var(--az-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 0.5rem;
  }

  .auth-form input {
    padding: 0.75rem 1rem;
    background: var(--az-deep);
    border: 1px solid var(--az-surface);
    border-radius: 6px;
    color: var(--az-text);
    font-family: var(--az-font-body);
    font-size: 1rem;
    transition: border-color 200ms;
  }

  .auth-form input:focus {
    outline: none;
    border-color: var(--az-compass);
  }

  .password-hint {
    font-size: 0.8rem;
    color: var(--az-text-muted);
    margin-top: -0.25rem;
    margin-bottom: 0.5rem;
  }

  .auth-btn {
    margin-top: 1.5rem;
    padding: 0.75rem;
    background: var(--az-compass);
    color: var(--az-void);
    border: none;
    border-radius: 6px;
    font-family: var(--az-font-display);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 200ms;
  }

  .auth-btn:hover {
    opacity: 0.9;
  }

  .auth-error {
    background: rgba(184, 92, 74, 0.15);
    border: 1px solid var(--az-ember);
    color: var(--az-ember);
    padding: 0.75rem 1rem;
    border-radius: 6px;
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .auth-success {
    background: rgba(90, 138, 106, 0.15);
    border: 1px solid var(--az-growth);
    color: var(--az-growth);
    padding: 0.75rem 1rem;
    border-radius: 6px;
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }
</style>
