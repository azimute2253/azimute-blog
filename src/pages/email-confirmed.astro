---
export const prerender = false;

import Base from '../layouts/Base.astro';
import { getLang, t } from '../lib/i18n';

const lang = getLang(Astro.cookies, Astro.url);
---
<Base title={t(lang, 'auth.confirmed.title')}>
  <div class="auth-page">
    <div class="confirmation-success">
      <svg class="success-icon" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/>
        <path d="M9 12l2 2 4-4"/>
      </svg>

      <h1>{t(lang, 'auth.confirmed.title')}</h1>
      <p class="success-message">{t(lang, 'auth.confirmed.success')}</p>
      <p class="auth-subtitle">{t(lang, 'auth.confirmed.canLogin')}</p>

      <a href="/login" class="auth-btn">{t(lang, 'auth.confirmed.loginBtn')}</a>
    </div>
  </div>
</Base>

<style>
  .auth-page {
    max-width: 400px;
    margin: 2rem auto;
  }

  .confirmation-success {
    text-align: center;
    padding: 2rem 0;
  }

  .success-icon {
    color: var(--az-growth);
    margin-bottom: 1.5rem;
  }

  .success-message {
    font-size: 1.125rem;
    margin-bottom: 1rem;
  }

  .auth-subtitle {
    color: var(--az-text-muted);
    margin-bottom: 2rem;
    font-size: 1rem;
  }

  .auth-btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: var(--az-compass);
    color: var(--az-void);
    text-decoration: none;
    border-radius: 6px;
    font-family: var(--az-font-display);
    font-size: 1rem;
    font-weight: 600;
    transition: opacity 200ms;
  }

  .auth-btn:hover {
    opacity: 0.9;
  }
</style>
