---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const wanders = await getCollection('wanders');
  const sorted = wanders.sort((a, b) => a.data.date.localeCompare(b.data.date));
  return sorted.map((post, i) => ({
    params: { date: post.data.date },
    props: {
      post,
      prev: i > 0 ? sorted[i - 1] : null,
      next: i < sorted.length - 1 ? sorted[i + 1] : null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.excerpt,
  "datePublished": post.data.date,
  "author": {
    "@type": "Person",
    "name": "Azimute",
    "url": "https://azimute.cc/about/"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Azimute",
    "url": "https://azimute.cc"
  },
  "url": canonicalURL,
  "mainEntityOfPage": canonicalURL,
  "keywords": post.data.layers.join(', ')
};
---

<Base title={post.data.title} description={post.data.excerpt} jsonLd={jsonLd}>
  <article>
    <div class="post-header">
      <span class="post-tag">hypnagogic wander · {post.data.theme}</span>
      <h1 class="post-title">{post.data.title}</h1>
      <div class="post-meta">
        {post.data.date} · {post.data.readingTime} · {post.data.layers.join(' ')}
      </div>
    </div>

    <div class="post-content">
      <Content />
    </div>

    <nav class="post-nav">
      <div class="post-nav-row">
        {next ? (
          <a href={`/wander/${next.data.date}/`} class="nav-prev">← {next.data.title}</a>
        ) : <span />}
        {prev ? (
          <a href={`/wander/${prev.data.date}/`} class="nav-next">{prev.data.title} →</a>
        ) : <span />}
      </div>
      <a href="/" class="nav-all">All wanders</a>
    </nav>
  </article>
</Base>

<style>
  .post-nav {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--az-surface);
  }
  .post-nav-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .nav-prev, .nav-next {
    font-family: var(--az-font-mono);
    font-size: 0.8rem;
    color: var(--az-text-muted);
    max-width: 45%;
  }
  .nav-next {
    text-align: right;
  }
  .nav-prev:hover, .nav-next:hover {
    color: var(--az-compass);
  }
  .nav-all {
    font-family: var(--az-font-mono);
    font-size: 0.875rem;
    color: var(--az-text-muted);
  }
  .nav-all:hover {
    color: var(--az-compass);
  }
</style>
